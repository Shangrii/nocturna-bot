# Copia este archivo a .env y rellena los valores.
#   cp .env.example .env

# ── Bot ───────────────────────────────────────────────────────────────────────
BOT_TOKEN=pon_aqui_tu_token
DISCORD_USER_ID=0          # tu ID de usuario (para comandos de admin)

# ── Servidor Discord ──────────────────────────────────────────────────────────
# Los comandos se sincronizan solo a este guild (instantáneo, sin duplicados).
GUILD_ID=0
ROLE_MODERATOR_ID=0

# ── Canales ───────────────────────────────────────────────────────────────────
ENCODING_CHANNEL_ID=0      # canal donde el encoder publica avances
FORUM_CHANNEL_ID=0         # foro de assets (etiquetas de avatares)
MEETINGS_FORUM_ID=0        # foro donde se publican las actas de reuniones

# ── HTTP local ────────────────────────────────────────────────────────────────
# encoder → bot (notificaciones)
NOTIFY_HOST=127.0.0.1
NOTIFY_PORT=8765
NOTIFY_URL=http://127.0.0.1:8765/notify

# bot → encoder (control: detener/reanudar/estado). Debe coincidir en ambos.
ENCODER_CONTROL_HOST=127.0.0.1
ENCODER_CONTROL_PORT=8766

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_PATH=bot.db

# ── Reuniones: transcripción (faster-whisper) ───────────────────────────────────
WHISPER_MODEL=large-v3-turbo   # tiny|base|small|medium|large-v3|large-v3-turbo
WHISPER_DEVICE=cuda            # "cpu" si no hay GPU NVIDIA con CUDA
WHISPER_COMPUTE=int8           # int8 (poca VRAM/RAM) | float16 (GPU grande)
WHISPER_THREADS=4              # hilos CPU (deja margen al encoder)
MEETING_LANG=es
WHISPER_PROMPT=Reunión en español del equipo Nocturna. Bot: CachoraBot.   # sesga nombres propios

# ── Reuniones: resumen (Ollama) ─────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=phi4              # corre en CPU; phi4 (14B) = notas/tareas precisas

# ── Galería (Fase 5: cog de publicación de fotos) ───────────────────────────────
PHOTO_CHANNEL_ID=1416329356426481717   # canal público donde el staff sube fotos
GALLERY_STAFF_ROLE_IDS=                # IDs de rol separados por comas (ej: 123,456); solo estos publican/quitan
GITHUB_PAT=                            # PAT fine-grained (Contents: read/write) — NUNCA subas uno real aquí
WEBSITE_REPO=Shangrii/Nocturna-Avatars # repo del sitio destino (owner/name)
WEBSITE_BRANCH=revamp                  # rama destino; cámbiala en el cutover a producción (D-15)
WEBSITE_GALLERY_JSON=src/data/gallery.json  # ruta del JSON de la galería en el repo del sitio
WEBSITE_IMAGE_DIR=public/gallery       # directorio de imágenes en el repo del sitio

# ── Reseñas (Fase 7: cog de publicación de reseñas) ─────────────────────────────
# Reutiliza GITHUB_PAT / WEBSITE_REPO / WEBSITE_BRANCH de la galería (mismo repo destino).
REVIEWS_CHANNEL_ID=1453534905706221600 # canal donde los clientes dejan reseñas (default de fábrica)
REVIEWS_STAFF_ROLE_IDS=                # IDs de rol separados por comas; vacío → usa GALLERY_STAFF_ROLE_IDS
WEBSITE_REVIEWS_JSON=src/data/reviews.json  # ruta del JSON de reseñas en el repo del sitio

# ── Recordatorios (Fase 8: cog de recordatorios programados) ─────────────────────
REMINDERS_TZ=America/Mexico_City       # zona horaria IANA para interpretar las horas del staff
REMINDERS_STAFF_ROLE_IDS=              # IDs de rol separados por comas; vacío → usa GALLERY_STAFF_ROLE_IDS
REMINDERS_CATCHUP_GRACE_HOURS=6        # ventana (h) para disparar atrasados tras una caída (6–12)

# ── Jinxxy (Fase 9: sync de la tienda) ───────────────────────────────────────────
# Reutiliza GITHUB_PAT / WEBSITE_REPO / WEBSITE_BRANCH de la galería (mismo repo destino).
JINXXY_API_KEY=                        # clave de la Creator API de Jinxxy — NUNCA subas una real aquí (déjala en blanco)
JINXXY_ANNOUNCE_CHANNEL_ID=1525202600738295818  # canal donde el cog anuncia altas/cambios/bajas (D-18)
JINXXY_POLL_HOURS=6                    # cadencia del poll en horas (banda 6–12; D-03)
WEBSITE_STORE_JSON=src/data/store.json # ruta del JSON de la tienda en el repo del sitio
WEBSITE_STORE_IMAGE_DIR=public/store   # directorio de imágenes de la tienda (servido como /store/<archivo>)
JINXXY_STAFF_ROLE_IDS=                 # IDs de rol separados por comas; vacío → usa GALLERY_STAFF_ROLE_IDS
WEBSITE_BASE_URL=https://nocturna-avatars.site       # origen del sitio; base para la miniatura del anuncio (/store/<archivo>.webp → URL absoluta)
JINXXY_STORE_URL=https://nocturna-avatars.site/en/store  # página de tienda (EN) a la que enlaza el embed público de anuncios
